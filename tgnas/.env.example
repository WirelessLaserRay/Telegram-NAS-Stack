# 核心凭据 (必填)
TGNAS_SECRET_KEY=your_secure_s3_secret_here
TGNAS_TELEGRAM_BOT_TOKEN=123456789:YOUR_BOT_TOKEN
TGNAS_TELEGRAM_CHAT_ID=-100123456789

# 代理设置 (如果你的网络直连 Telegram 有问题，请配置代理，例如你本机的 Clash)
# 如果本机代理运行在 7890 端口，可取消下方注释
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890

# 暴露给宿主机的端口 (默认 9000)
TGNAS_PORT_EXPOSED=9000
